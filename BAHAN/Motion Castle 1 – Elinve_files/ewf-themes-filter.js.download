(function($) {
    var EWFThemeFilterLogic = function($scope) {
        var widgetId = $scope.data('id');
        var dataKey = 'ewfThemesData_' + widgetId;

        if (typeof window[dataKey] === 'undefined') {
            return;
        }

        if (typeof window.ewfThemeAjax === 'undefined' || !window.ewfThemeAjax.ajax_url) {
            console.error('EWF Theme Filter: Data AJAX global (ewfThemeAjax) tidak tersedia. Pastikan plugin utama melokalkan skrip ewf-themes-filter dengan benar.');
        }

        var settings = window[dataKey];
        var colorsData = settings.colors || [];
        var initialItems = settings.initial_items || 6;
        var loadMoreStep = settings.load_more_step || 4;
        var specialDomains = settings.special_domains || [];
        var loadMoreButtonText = settings.load_more_button_text || 'Lihat Tema Lain';

        var brandName = settings.brand_name || '';
        var affiliateName = settings.affiliate_name || '';

        var $container = $('#ewf-themes-container-' + widgetId);
        var $modalOverlay = $('#ewf-order-modal-' + widgetId);
        var $modalNotes = $modalOverlay.find('.ewf-modal-notes');

        var checkIsSpecialDomain = function() {
            const currentHostname = window.location.hostname.toLowerCase();
            return specialDomains.some(domain => {
                const cleanDomain = domain.trim().toLowerCase();
                return currentHostname === cleanDomain;
            });
        };

        var applyConditionalNotesLogic = function() {
            const isSpecialDomain = checkIsSpecialDomain();
            if (isSpecialDomain) {
                $modalNotes.slideDown(200).css('display', 'block');
            } else {
                $modalNotes.slideUp(200).css('display', 'none');
            }
        };

        var applyConditionalRadioLogic = function() {
            const isSpecialDomain = checkIsSpecialDomain();
            const $conditionalRadioSection = $modalOverlay.find('.ewf-modal-section[data-conditional-radio="true"]');

            if ($conditionalRadioSection.length === 0) {
                return;
            }

            const $radioInputs = $conditionalRadioSection.find('input[type="radio"][data-is-conditional="true"]');

            if (isSpecialDomain) {
                $conditionalRadioSection.removeClass('ewf-conditional-radio-hidden').show();
                $radioInputs.each(function() {
                    $(this).attr('required', 'required');
                });
            } else {
                $conditionalRadioSection.addClass('ewf-conditional-radio-hidden').hide();
                $radioInputs.each(function() {
                    $(this).removeAttr('required');
                });
            }
        };

        var defaultWANumberRaw = settings.default_whatsapp_number || '';
        var adminWANumberRaw = settings.admin_whatsapp_number || '';
        var clientCustomMessage = settings.client_custom_message || '';
        var adminCustomMessage = settings.admin_custom_message || '';
        var customFieldNames = settings.custom_field_names || [];
        var $toggleBtn = $container.find('.ewf-color-filter-toggle');
        var $dropdown = $container.find('.ewf-color-filters-dropdown');
        var $grid = $('#ewf-themes-grid-' + widgetId);
        var $loadMoreBtn = $container.find('.ewf-load-more-button');
        var $allItems = $grid.find('.ewf-theme-item');
        var totalItems = $allItems.length;
        var currentFilterColor = 'ALL';
        var currentSearchTerm = '';
        var currentVisibleIndices = [];
        var $noResultsMessage = $grid.find('.ewf-no-results');

        if ($noResultsMessage.length === 0) {
            $noResultsMessage = $('<div class="ewf-no-results" style="display: none; text-align: center; padding: 30px 0 0; grid-column: 1 / -1;"><h3>Tema Tidak Tersedia</h3><p>Maaf, tidak ada tema yang cocok dengan kriteria filter Anda.</p></div>');
            $grid.append($noResultsMessage);
        } else {
            $noResultsMessage.hide();
        }

        var formatPriceJS = function(num) {
            if (typeof num === 'string') {
                num = num.replace(/[^0-9]/g, '');
            }
            if (!num || isNaN(parseInt(num))) return '0';
            return parseInt(num).toLocaleString('id-ID');
        };

        var collectCustomFields = function() {
            var fields = {};
            var isValid = true;

            $modalOverlay.find('.ewf-input-error').removeClass('ewf-input-error');
            $modalOverlay.find('.ewf-global-error-message').hide();

            customFieldNames.forEach(function(fieldConfig) {
                var fieldName = fieldConfig.name;
                var $field = $modalOverlay.find('[name="' + fieldName + '"].ewf-gateway-input');
                var value = '';

                if ($field.attr('type') === 'radio' || $field.attr('type') === 'checkbox') {
                    value = $field.filter(':checked').val() || '';

                    if (fieldConfig.required && !value) {
                        if (!(fieldConfig.is_conditional_radio && $modalOverlay.find('.ewf-modal-section[data-field-name="' + fieldName + '"]').hasClass('ewf-conditional-radio-hidden'))) {
                            isValid = false;
                            $modalOverlay.find('.ewf-modal-section[data-field-name="' + fieldName + '"]').addClass('ewf-input-error');
                        }
                    } else {
                        $modalOverlay.find('.ewf-modal-section[data-field-name="' + fieldName + '"]').removeClass('ewf-input-error');
                    }
                } else {
                    value = $field.val() || '';

                    if (fieldConfig.required && value.trim() === '') {
                        isValid = false;
                        $field.addClass('ewf-input-error');
                    } else {
                        $field.removeClass('ewf-input-error');
                    }

                    if (fieldName === 'user_wa' && value.length > 0 && value.length < 8) {
                        isValid = false;
                        $field.addClass('ewf-input-error');
                    } else if (fieldName === 'user_wa' && value.length >= 8) {
                        $field.removeClass('ewf-input-error');
                    }
                }
                fields[fieldName] = value;
            });
            return {
                fields: fields,
                isValid: isValid
            };
        };

        var resolveDynamicTags = function(rawString, themeTitle, priceDiscount, priceNormal, brandName, affiliateName) {
            var resolvedString = rawString.replace(/\[JUDUL\]/g, themeTitle);
            resolvedString = resolvedString.replace(/\[HARGA_DISKON\]/g, priceDiscount);
            resolvedString = resolvedString.replace(/\[HARGA_NORMAL\]/g, priceNormal);
            resolvedString = resolvedString.replace(/\[BRAND_NAME\]/g, brandName);
            resolvedString = resolvedString.replace(/\[AFFILIATE_NAME\]/g, affiliateName);
            return resolvedString;
        };

        var generateResolvedMessage = function(themeTitle, priceDiscountRaw, priceNormalRaw, customFields, rawMessage, rawTargetNumber) {
            var resolvedTargetWANumber = resolveDynamicTags(rawTargetNumber, themeTitle, priceDiscountRaw, priceNormalRaw, brandName, affiliateName);
            var targetNumber = resolvedTargetWANumber.replace(/\D/g, '');

            if (targetNumber.startsWith('0')) {
                targetNumber = '62' + targetNumber.substring(1);
            } else if (!targetNumber.startsWith('62') && targetNumber.length > 0) {
                targetNumber = '62' + targetNumber;
            }

            if (targetNumber.length < 8) return {
                success: false,
                number: '',
                message: ''
            };

            var message = rawMessage.replace(/\|\|LINE_BREAK\|\|/g, '\n');
            var allInputsText = '';
            
            var metodePembuatanValue = customFields.fields['metode_pembuatan'] || '';
            var emptyMethodTag = 'Metode Pembuatan : '; 

            if (metodePembuatanValue.trim() !== '') {
                var tagMetodeRegex = new RegExp('\\[METODE_PEMBUATAN\\]', 'g');
                message = message.replace(tagMetodeRegex, metodePembuatanValue);

                var regexHideLine = new RegExp(
                    '\\n\\s*' + emptyMethodTag.replace(/[-\/\\^$*+?.()|[\]{}]/g, '\\$&') + '\\s*', 
                    'g'
                );
                message = message.replace(regexHideLine, '\n' + emptyMethodTag);
            } else {
                var tagMetodeRegex = new RegExp('\\[METODE_PEMBUATAN\\]', 'g');
                message = message.replace(tagMetodeRegex, '');

                var regexHideLine = new RegExp(
                    '\\n\\s*' + emptyMethodTag.replace(/[-\/\\^$*+?.()|[\]{}]/g, '\\$&') + '\\s*', 
                    'g'
                );
                message = message.replace(regexHideLine, '\n');
                
                if (message.startsWith(emptyMethodTag.trim())) {
                    message = message.replace(emptyMethodTag.trim(), '').trim();
                }
            }


            for (var fieldName in customFields.fields) {
                var value = customFields.fields[fieldName];

                if (value) {
                    var $label = $modalOverlay.find('[name="' + fieldName + '"]').first().closest('.ewf-modal-section').find('.ewf-modal-label');
                    var labelText = $label.text().replace(/:$/, '').trim() || fieldName;
                    allInputsText += "*" + labelText + ":* " + value + "\n";
                }
                
                if (fieldName === 'metode_pembuatan') continue;

                var tagRegex = new RegExp('\\[' + fieldName.toUpperCase() + '\\]', 'g');
                var replacementValue = value || '';
                message = message.replace(tagRegex, replacementValue);
            }

            message = message.replace(/\[JUDUL\]/g, themeTitle);
            message = message.replace(/\[HARGA_DISKON\]/g, 'Rp ' + formatPriceJS(priceDiscountRaw));
            message = message.replace(/\[HARGA_NORMAL\]/g, 'Rp ' + formatPriceJS(priceNormalRaw));
            message = message.replace(/\[BRAND_NAME\]/g, brandName);
            message = message.replace(/\[AFFILIATE_NAME\]/g, affiliateName);
            message = message.replace(/\[ALL_INPUTS\]/g, allInputsText.trim());

            message = message.trim();

            return {
                success: true,
                number: targetNumber,
                message: message
            };
        };

        var sendFonnteMessage = function(targetNumber, messageText) {
            if (typeof ewfThemeAjax === 'undefined' || !ewfThemeAjax.ajax_url) {
                console.error('Fonnte API: AJAX data global tidak tersedia.');
                return;
            }
            if (!targetNumber || !messageText) {
                console.error('Fonnte API: Nomor atau pesan tidak valid.');
                return;
            }

            $.ajax({
                url: ewfThemeAjax.ajax_url,
                method: 'POST',
                data: {
                    action: ewfThemeAjax.action,
                    security: ewfThemeAjax.nonce,
                    target_number: targetNumber,
                    message_text: messageText
                },
                success: function(response) {
                    if (response.success) {
                        console.log('Fonnte Admin Success (via AJAX):', response.data);
                    } else {
                        console.error('Fonnte Admin Error (via AJAX):', response.data.message, response.data.response_body);
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Fonnte Admin AJAX Failed:', error, xhr.responseText);
                }
            });
        };

        var closeModal = function() {
            $modalOverlay.addClass('ewf-modal-hidden');
            $('body').removeClass('ewf-modal-open');
            $modalOverlay.find('.ewf-modal-text-input').val('');
            $modalOverlay.find('.ewf-global-error-message').hide();
            $modalOverlay.find('.ewf-input-error').removeClass('ewf-input-error');
            $modalOrderLink.attr('data-client-link', '#').prop('disabled', false).removeClass('disabled');
            $modalOverlay.find('.ewf-gateway-input').off('input.ewfModalUpdate change.ewfModalUpdate');
        };

        var updateLuckyText = function(themeTitle, priceDiscountRaw, priceNormalRaw) {
            var $luckyTextEl = $modalOverlay.find('.ewf-modal-lucky-text');
            if ($luckyTextEl.length) {
                var resolvedText = resolveDynamicTags(settings.modal_lucky_text, themeTitle, formatPriceJS(priceDiscountRaw), formatPriceJS(priceNormalRaw), brandName, affiliateName);
                $luckyTextEl.text(resolvedText);
            }
        };

        var getHiddenFilteredItems = function() {
            return $allItems.filter(function() {
                const $item = $(this);
                const isHidden = $item.css('display') === 'none' || $item.is(':hidden');

                if (isHidden) {
                    const searchData = $item.data('search');
                    if (!searchData) return false;

                    let matchesFilter = currentFilterColor === 'ALL';
                    if (currentFilterColor !== 'ALL') {
                        const itemColors = searchData.colors ? searchData.colors.split(',') : [];
                        if (itemColors.includes(currentFilterColor)) {
                            matchesFilter = true;
                        }
                    }

                    let matchesSearch = currentSearchTerm.length === 0;
                    if (currentSearchTerm.length > 0) {
                        const searchableText = (searchData.name + ' ' + searchData.badge + ' ' + searchData.ribbon + ' ' + searchData.term_slug).toLowerCase();
                        if (searchableText.indexOf(currentSearchTerm) !== -1) {
                            matchesSearch = true;
                        }
                    }

                    return matchesFilter && matchesSearch;
                }
                return false;
            });
        };

        var updateLoadMoreStatus = function() {
            const totalMatchingItems = $allItems.filter(function() {
                const $item = $(this);
                const searchData = $item.data('search');
                if (!searchData) return false;

                let matchesFilter = currentFilterColor === 'ALL';
                if (currentFilterColor !== 'ALL') {
                    const itemColors = searchData.colors ? searchData.colors.split(',') : [];
                    if (itemColors.includes(currentFilterColor)) matchesFilter = true;
                }

                let matchesSearch = currentSearchTerm.length === 0;
                if (currentSearchTerm.length > 0) {
                    const searchableText = (searchData.name + ' ' + searchData.badge + ' ' + searchData.ribbon + ' ' + searchData.term_slug).toLowerCase();
                    if (searchableText.indexOf(currentSearchTerm) !== -1) matchesSearch = true;
                }
                return matchesFilter && matchesSearch;
            }).length;

            const currentVisible = $allItems.filter(function() {
                return $(this).css('display') !== 'none';
            }).length;

            if (currentVisible >= totalMatchingItems) {
                $loadMoreBtn.hide();
            } else {
                $loadMoreBtn.show();
            }
        };

        var applyFilters = function() {
            let totalItemsFiltered = 0;
            currentVisibleIndices = [];

            $allItems.each(function(index) {
                const $item = $(this);
                const searchData = $item.data('search');
                if (!searchData) return;

                let showByFilter = true;
                if (currentFilterColor !== 'ALL') {
                    const itemColors = searchData.colors ? searchData.colors.split(',') : [];
                    if (!itemColors.includes(currentFilterColor)) showByFilter = false;
                }
                if (currentSearchTerm.length > 0) {
                    const searchableText = (searchData.name + ' ' + searchData.badge + ' ' + searchData.ribbon + ' ' + searchData.term_slug).toLowerCase();
                    if (searchableText.indexOf(currentSearchTerm) === -1) showByFilter = false;
                }

                if (showByFilter) {
                    totalItemsFiltered++;

                    if (currentVisibleIndices.length < initialItems) {
                        $item.show();
                        currentVisibleIndices.push(index);
                    } else {
                        $item.hide();
                    }
                } else {
                    $item.hide();
                }
            });

            if (totalItemsFiltered === 0) {
                $noResultsMessage.show();
            } else {
                $noResultsMessage.hide();
            }

            updateLoadMoreStatus();
        };

        var loadMoreItems = function() {
            $loadMoreBtn.addClass('loading').prop('disabled', true).html('<span class="ewf-loader"></span> ' + loadMoreButtonText);

            setTimeout(function() {
                const $hiddenItems = getHiddenFilteredItems().slice(0, loadMoreStep);

                $hiddenItems.each(function() {
                    $(this).fadeIn(400);
                });

                $loadMoreBtn.removeClass('loading').prop('disabled', false).html(loadMoreButtonText);
                updateLoadMoreStatus();
            }, 800);
        };

        var $orderButtons = $container.find('.ewf-button-order-modal');

        var $modalTitle = $modalOverlay.find('.ewf-modal-title');
        var $modalImage = $modalOverlay.find('.ewf-modal-image');
        var $modalPriceNormal = $modalOverlay.find('.price-normal-modal');
        var $modalPriceDiscount = $modalOverlay.find('.price-discount-modal');
        var $modalOrderLink = $modalOverlay.find('.ewf-modal-order-link');
        var $modalCloseBtn = $modalOverlay.find('.ewf-modal-close-btn');


        $orderButtons.on('click.ewfModal' + widgetId, function() {
            var $btn = $(this);
            var themeTitle = $btn.data('title');
            var priceNormalRaw = $btn.data('price-normal');
            var priceDiscountRaw = $btn.data('price-discount');
            var themeImage = $btn.data('image');

            $modalTitle.text(themeTitle);
            $modalImage.attr('src', themeImage).attr('alt', themeTitle);
            $modalPriceNormal.text('Rp ' + formatPriceJS(priceNormalRaw)).toggleClass('price-strike', !!priceNormalRaw && priceNormalRaw !== priceDiscountRaw);
            $modalPriceDiscount.text('Rp ' + formatPriceJS(priceDiscountRaw));

            updateLuckyText(themeTitle, priceDiscountRaw, priceNormalRaw);
            applyConditionalRadioLogic();
            applyConditionalNotesLogic();

            var updateLink = function() {
                var customFieldsData = collectCustomFields();

                var clientResolved = generateResolvedMessage(
                    themeTitle, priceDiscountRaw, priceNormalRaw, customFieldsData, clientCustomMessage, defaultWANumberRaw
                );

                var finalClientLink = clientResolved.success ?
                    "https://wa.me/" + clientResolved.number + "?text=" + encodeURIComponent(clientResolved.message) :
                    "#";

                $modalOrderLink.attr('data-client-link', finalClientLink);

            };

            $modalOverlay.find('.ewf-gateway-input').on('input.ewfModalUpdate change.ewfModalUpdate', updateLink);
            updateLink();

            $modalOverlay.removeClass('ewf-modal-hidden');
            $('body').addClass('ewf-modal-open');
        });


        $modalOrderLink.off('click.ewfFinalOrder').on('click.ewfFinalOrder', function(e) {
            e.preventDefault();

            var $btn = $(this);
            var customFieldsData = collectCustomFields();

            if (customFieldsData.isValid === false) {
                $modalOverlay.find('.ewf-global-error-message').show();
                $modalOverlay.find('.ewf-input-error').first().focus();
                return;
            }

            var themeTitle = $modalTitle.text().replace(/[^a-zA-Z0-9\s]/g, '').trim();
            var priceNormalText = $modalPriceNormal.text().replace(/[^0-9]/g, '');
            var priceDiscountText = $modalPriceDiscount.text().replace(/[^0-9]/g, '');
            var priceNormalRaw = priceNormalText.length > 0 ? priceNormalText : '0';
            var priceDiscountRaw = priceDiscountText.length > 0 ? priceDiscountText : '0';


            var adminResolved = generateResolvedMessage(
                themeTitle, priceDiscountRaw, priceNormalRaw, customFieldsData, adminCustomMessage, adminWANumberRaw
            );

            if (adminResolved.success && adminWANumberRaw) {
                sendFonnteMessage(adminResolved.number, adminResolved.message);
            }

            var clientLink = $btn.attr('data-client-link');
            if (clientLink && clientLink !== '#') {
                window.open(clientLink, '_blank');
                closeModal();
            } else {
                console.error('Gagal membuat tautan WhatsApp Klien.');
            }
        });


        $modalCloseBtn.on('click.ewfModal' + widgetId, closeModal);
        $modalOverlay.on('click.ewfModal' + widgetId, function(e) {
            if ($(e.target).is($modalOverlay)) {
                closeModal();
            }
        });
        $(document).off('keydown.ewfModal' + widgetId).on('keydown.ewfModal' + widgetId, function(e) {
            if (e.key === "Escape" && !$modalOverlay.hasClass('ewf-modal-hidden')) {
                closeModal();
            }
        });


        $loadMoreBtn.off('click.ewfFilter').on('click.ewfFilter', loadMoreItems);

        var $toggleBtn = $container.find('.ewf-color-filter-toggle');
        var $dropdown = $container.find('.ewf-color-filters-dropdown');

        $toggleBtn.off('click.ewfFilter').on('click.ewfFilter', function(e) {
            e.stopPropagation();
            $dropdown.toggleClass('ewf-color-filters-hidden');
            $(this).toggleClass('active');
        });

        var clickOutsideHandler = 'click.ewfFilter' + widgetId;
        $(document).off(clickOutsideHandler).on(clickOutsideHandler, function(event) {
            var $currentDropdown = $container.find('.ewf-color-filters-dropdown');
            var $currentTargetToggle = $container.find('.ewf-color-filter-toggle');

            if (
                !$currentDropdown.is(event.target) &&
                $currentDropdown.has(event.target).length === 0 &&
                !$currentTargetToggle.is(event.target) &&
                $currentTargetToggle.has(event.target).length === 0
            ) {
                if (!$currentDropdown.hasClass('ewf-color-filters-hidden')) {
                    $currentDropdown.addClass('ewf-color-filters-hidden');
                    $currentTargetToggle.removeClass('active');
                }
            }
        });

        if ($dropdown.length && colorsData.length && $dropdown.find('.ewf-color-filter-btn:not(.reset-btn)').length === 0) {
            var uniqueColors = [...new Set(colorsData)];
            uniqueColors.forEach(function(color) {
                var colorHex = color.toUpperCase().trim();
                var $btn = $('<button>')
                    .addClass('ewf-color-filter-btn')
                    .attr('data-color-filter', colorHex)
                    .attr('title', colorHex)
                    .css('background-color', color);
                $dropdown.append($btn);
            });
        }

        $dropdown.on('click.ewfFilter', '.ewf-color-filter-btn', function() {
            var filterValue = $(this).data('color-filter');
            currentFilterColor = filterValue;

            $dropdown.find('.ewf-color-filter-btn').removeClass('active');
            $(this).addClass('active');

            $allItems.each(function() {
                $(this).hide();
            });
            currentVisibleIndices = [];

            $container.find('.ewf-theme-search-input').val('');
            currentSearchTerm = '';

            applyFilters();
        });

        $container.find('.ewf-theme-search-input').on('keyup.ewfFilter', function() {
            currentSearchTerm = $(this).val().toLowerCase();

            $allItems.each(function() {
                $(this).hide();
            });
            currentVisibleIndices = [];

            applyFilters();
        });

        $allItems.filter(function(index) {
            return index < initialItems;
        }).show();
        $allItems.filter(function(index) {
            return index >= initialItems;
        }).hide();

        updateLoadMoreStatus();

        $dropdown.find('.reset-btn').addClass('active');

        applyConditionalNotesLogic();

        setTimeout(function() {
            applyFilters();
        }, 100);
    };

    var EWFThemeFilterHandler = function($scope) {
        EWFThemeFilterLogic($scope);
    };

    $(window).on('elementor/frontend/init', function() {
        elementorFrontend.hooks.addAction('frontend/element_ready/ewf-themes-widget.default', EWFThemeFilterHandler);
    });
})(jQuery);